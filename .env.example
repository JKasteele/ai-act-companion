# =====================================================================
#  AI Act Companion - example configuration
#  Copy to .env. The rule-based core (phases 1-3) uses NONE of this;
#  these variables are only for the optional AI layer (phase 4).
# =====================================================================

# Which LLM provider the AI layer uses: "ollama" | "manual" | "none"
#   ollama -> a local Ollama runs the prefill/narrative step
#   manual -> the app generates a prompt you paste into your own LLM session
#   none   -> AI layer off (rule-based only)
LLM_PROVIDER=ollama

# --- Ollama (local) ---
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen3:32b

# --- API provider (only if you choose this later) ---
# Note: a Claude Max subscription is NOT an API backend. For API use you need a
# separate, separately billed API key.
# ANTHROPIC_API_KEY=
